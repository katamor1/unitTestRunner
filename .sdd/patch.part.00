+def json_pointer_escape(value: str) -> str:
+    return value.replace("~", "~0").replace("/", "~1")
+
+
+def parent_json_pointer(item: LocatedFormItem) -> str:
+    return (
+        f"/{json_pointer_escape(item.case_location)}/{item.case_index}"
+        f"/{json_pointer_escape(item.collection)}/{item.item_index}"
+    )
+
+
+def child_json_pointer(item: LocatedFormItem, control_name: str) -> str:
+    return f"{parent_json_pointer(item)}/{json_pointer_escape(control_name)}"
+```
+
+Do not add `case_location`, `case_index`, or `item_index` to the item-ID locator hash. The existing item ID must remain location-independent.
+
+- [ ] **Step 4: Add the public immutable field descriptions**
+
+Add the dataclasses and `locate_editable_test_spec_fields` to `src/unit_test_runner/test_input_form/service.py`:
+
+```python
+@dataclass(frozen=True)
+class LocatedEditableControl:
+    name: str
+    json_pointer: str
+    value: Any
+    required_for_execution: bool
+    required_for_confirmation: bool
+
+
+@dataclass(frozen=True)
+class LocatedEditableField:
+    case_id: str
+    case_location: str
+    item_id: str
+    item_kind: str
+    label: str
+    parent_pointer: str
+    controls: tuple[LocatedEditableControl, ...]
+    confirmed: bool
+    execution_blocking: bool
+    editable: bool
+
+
+def locate_editable_test_spec_fields(
+    spec: Any,
+) -> tuple[LocatedEditableField, ...]:
+    result: list[LocatedEditableField] = []
+    for located in locate_form_items(spec):
+        controls = tuple(
+            LocatedEditableControl(
+                name=name,
+                json_pointer=child_json_pointer(located, name),
+                value=located.parent.get(name),
+                required_for_execution=execution_value_required(
+                    located.rule,
+                    name,
+                    located.parent,
+                ),
+                required_for_confirmation=required_for_confirmation(
+                    located.rule,
+                    name,
+                ),
+            )
+            for name in editable_control_names(located.rule)
+        )
+        confirmed = not bool(located.parent.get("review_required", False))
+        result.append(
+            LocatedEditableField(
+                case_id=located.case_id,
+                case_location=located.case_location,
+                item_id=located.item_id,
+                item_kind=located.kind,
+                label=label_for_parent(located.rule, located.parent),
+                parent_pointer=parent_json_pointer(located),
+                controls=controls,
+                confirmed=confirmed,
+                execution_blocking=any(
+                    item.required_for_execution for item in controls
+                ),
+                editable=located.editable,
+            )
+        )
+    return tuple(result)
+```
+
+Export the dataclasses and function from `src/unit_test_runner/test_input_form/__init__.py`.
