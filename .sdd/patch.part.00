+def test_blocked_run_writes_direct_fields_then_non_blocked_run_clears_latest(self):
+    with tempfile.TemporaryDirectory() as temp_dir:
+        workspace = prepare_executable_fixture_with_unconfirmed_candidate(
+            Path(temp_dir)
+        )
+
+        blocked = run_cli(
+            "--json",
+            "run-tests",
+            "--workspace",
+            str(workspace),
+            "--run",
+            "--run-id",
+            "run-blocked-e2e",
+        )
+
+        self.assertEqual(35, blocked.returncode, blocked.stderr)
+        blocker_payload = json.loads(
+            (
+                workspace
+                / "runs/run-blocked-e2e/test_execution_blockers.json"
+            ).read_text(encoding="utf-8")
+        )
+        blockers = blocker_payload["data"]["blockers"]
+        self.assertTrue(blockers)
+        concrete = next(
+            item for item in blockers
+            if item["category"] == "test_input"
+        )
+        self.assertTrue(concrete["case_id"])
+        self.assertTrue(concrete["item_id"])
+        self.assertTrue(concrete["source_pointer"].startswith("/"))
+        self.assertEqual(
+            "reports/test_spec.json",
