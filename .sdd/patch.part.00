+Implement:
+
+```python
+_CATEGORY_ORDER = {
+    "build_probe": 0,
+    "executable": 1,
+    "harness": 2,
+    "test_case": 3,
+    "test_input": 4,
+    "runner": 5,
+    "unknown": 6,
+}
+
+
+def _dedup_key(item: PendingBlocker) -> tuple[str, str, str, str, str, str]:
+    return (
+        item.code,
+        item.case_id or "",
+        item.item_id or "",
+        item.control_name or "",
+        item.source_artifact.as_posix() if item.source_artifact else "",
+        item.source_pointer or "",
+    )
+
+
+def _sort_key(item: PendingBlocker) -> tuple[int, str, str, str, str, str]:
+    return (
+        _CATEGORY_ORDER[item.category],
+        item.case_id or "",
+        item.item_id or "",
+        item.control_name or "",
+        item.source_pointer or "",
+        item.code,
+    )
+```
