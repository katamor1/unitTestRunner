+```
+
+Implement build analysis with this decision order:
+
+```python
+def _build_probe_blockers(
+    build_probe_report: Mapping[str, Any],
+) -> list[PendingBlocker]:
+    status = str(
+        build_probe_report.get("function", {}).get("status") or "unknown"
+    )
+    if status == "succeeded":
+        return []
+
+    diagnostics = [
+        item
+        for item in build_probe_report.get("diagnostics", [])
+        if isinstance(item, Mapping) and item.get("severity") == "error"
+    ]
+    if diagnostics:
+        return [
+            PendingBlocker(
+                code=str(item.get("code") or "build_probe_error"),
+                category="build_probe",
+                severity="error",
+                summary=_bounded_text(
+                    str(item.get("message") or "ビルドプローブに失敗しました。"),
+                    4096,
+                ).text,
+                related_file=_safe_relative_path(item.get("file")),
+                line_number=_positive_int(item.get("line_number")),
+                source_artifact=Path("reports/build_probe_report.json"),
+                source_pointer=f"/diagnostics/{index}",
+                recommended_action=OPEN_BUILD_PROBE_REPORT,
+                next_steps=(
+                    "ビルド診断を確認する",
+                    "ビルドを再実行する",
+                    "テストを再実行する",
+                ),
+            )
+            for index, item in enumerate(diagnostics)
+        ]
+
+    action = RUN_BUILD_PROBE if status in {"not_run", "generated"} else OPEN_BUILD_PROBE_REPORT
+    return [
+        PendingBlocker(
+            code="build_probe_not_successful",
+            category="build_probe",
+            severity="error",
+            summary="ビルドプローブが成功していません。",
+            source_artifact=Path("reports/build_probe_report.json"),
+            source_pointer="/function/status",
+            current_value=status,
+            recommended_action=action,
+            next_steps=(
+                "ビルド結果を確認する",
+                "ビルドを成功させる",
+                "テストを再実行する",
+            ),
+        )
+    ]
+```
+
+When `report.executable` exists but `exists` is false, emit exactly one `executable_not_found` blocker sourced from `reports/build_probe_report.json`, use a workspace-relative attempted path only when safe, include `build_probe_status` in the bounded summary, and recommend `CHOOSE_OR_BUILD_EXECUTABLE`.
