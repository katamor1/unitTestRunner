+
+```typescript
+export function isHandledBlockedTestRun(
+  request: CliCommand,
+  processExitCode: number,
+  envelope: ParsedCliEnvelope,
+): boolean {
+  return processExitCode === 35
+    && envelope.version === '1.0.0'
+    && envelope.command === 'run-tests'
+    && envelope.outcome === 'blocked'
+    && envelope.exitCode === 35
+    && request.args.includes('run-tests')
+    && request.args.includes('--run');
+}
+```
+
+The adapter still parses the complete stdout envelope before this decision. If parsing fails, command/outcome mismatches, `--run` is absent, or the envelope exit code differs, throw the existing CLI process error.
+
+Return valid blocked results through the same result type used by zero-exit structured commands; do not mark them green or successful.
