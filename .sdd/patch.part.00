+```python
+import json
+import os
+import subprocess
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+SRC_ROOT = REPO_ROOT / "src"
+
+
+def run_module(*args: str) -> subprocess.CompletedProcess[str]:
+    env = os.environ.copy()
+    env["PYTHONPATH"] = str(SRC_ROOT)
+    return subprocess.run(
+        [sys.executable, "-m", "unit_test_runner", *args],
+        cwd=REPO_ROOT,
+        env=env,
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        check=False,
+    )
+
+
+class ExecutionBlockerCliTests(unittest.TestCase):
+    def test_blocked_cli_returns_exit_35_and_actionable_details(self):
+        with tempfile.TemporaryDirectory() as temp_dir:
+            workspace = prepare_blocked_cli_workspace(Path(temp_dir))
+
+            completed = run_module(
+                "--json",
+                "run-tests",
+                "--workspace",
+                str(workspace),
+                "--run",
+                "--run-id",
+                "run-blocked-cli",
+            )
+
+        self.assertEqual(35, completed.returncode, completed.stderr)
+        payload = json.loads(completed.stdout)
+        data = payload["data"]
+        self.assertEqual("run-tests", data["command"])
+        self.assertEqual("test_run", data["outcome_kind"])
+        self.assertEqual("blocked", data["outcome"])
+        self.assertFalse(data["green"])
+        self.assertEqual(35, data["exit_code"])
+        blockers = data["details"]["blockers"]
+        self.assertGreater(blockers["count"], 0)
+        self.assertEqual(
+            "open_test_input_editor",
+            blockers["primary_action"],
+        )
+        self.assertEqual(
+            "reports/test_execution_blockers.md",
+            blockers["latest_markdown"],
+        )
+        self.assertIn(
+            "See reports/test_execution_blockers.md",
+            data["message"],
+        )
+        artifact_kinds = {
+            item["artifact_kind"] for item in data["artifacts"]
+        }
+        self.assertIn("test_execution_blocker_report", artifact_kinds)
+
+    def test_publication_warning_keeps_blocked_details_without_claiming_paths(self):
+        # Patch publication at the command/service boundary to return one blocker,
+        # no paths, and diagnostic blocker_report_write_failed.
+        # Assert exit 35, outcome blocked, count and primary action present,
+        # no path keys, diagnostic present, and no blocker produced artifact.
+```
