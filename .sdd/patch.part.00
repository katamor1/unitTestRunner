+    test_spec: Mapping[str, Any],
+) -> list[PendingBlocker]:
+    no_cases = not list(test_spec.get("test_cases") or [])
+    placeholder_blocked = any(
+        item.code == "placeholder_tests_not_allowed"
+        for item in report.warnings
+    )
+    if not no_cases and not placeholder_blocked:
+        return []
+
+    result: list[PendingBlocker] = []
+    for field in locate_editable_test_spec_fields(test_spec):
+        if not field.execution_blocking or not field.editable:
+            continue
+
+        unresolved_controls = [
+            control
+            for control in field.controls
+            if control.required_for_execution
+            and is_unresolved_test_input(control.value)
+        ]
+        if unresolved_controls:
+            for control in unresolved_controls:
+                bounded = _bounded_text(
+                    "" if control.value is None else str(control.value),
+                    2048,
+                )
+                result.append(
+                    PendingBlocker(
+                        code="unresolved_test_input",
+                        category="test_input",
+                        severity="error",
+                        case_id=field.case_id,
+                        item_id=field.item_id,
+                        control_name=control.name,
+                        summary=f"{field.label} の値が未確定です。",
+                        current_value=bounded.text,
+                        source_artifact=Path("reports/test_spec.json"),
+                        source_pointer=control.json_pointer,
+                        recommended_action=OPEN_TEST_INPUT_EDITOR,
+                        next_steps=(
+                            "値を入力する",
+                            "項目を確認済みにする",
+                            "テストハーネスを再生成する",
+                            "ビルドを実行する",
+                            "テストを再実行する",
+                        ),
+                        truncated=bounded.truncated,
+                    )
+                )
+            continue
+
+        if field.case_location == "additional_case_candidates" and not field.confirmed:
+            result.append(
+                PendingBlocker(
+                    code="unconfirmed_test_input",
+                    category="test_input",
+                    severity="error",
+                    case_id=field.case_id,
+                    item_id=field.item_id,
+                    summary=f"{field.label} は入力済みですが確認されていません。",
+                    current_value=_field_value_summary(field),
+                    source_artifact=Path("reports/test_spec.json"),
+                    source_pointer=field.parent_pointer,
+                    recommended_action=OPEN_TEST_INPUT_EDITOR,
+                    next_steps=(
+                        "項目を確認済みにする",
+                        "テストハーネスを再生成する",
+                        "ビルドを実行する",
+                        "テストを再実行する",
+                    ),
+                )
+            )
+    return result
+```
+
+Emit generic `no_executable_test_cases` only when the broad condition exists and the concrete TestSpec result is empty.
+
+- [ ] **Step 6: Add harness and runner extraction**
+
+Implement these exact precedence rules:
+
+1. Map current TestSpec concrete blockers first.
+2. For each harness `unresolved_placeholders` entry not represented by a concrete blocker case/control, emit one `placeholder_tests_not_allowed` sourced from `reports/harness_skeleton_report.json` with pointer `/unresolved_placeholders/<index>`.
+3. If the harness is missing or its function/status indicates stale/incomplete generation, emit one `harness_missing_or_stale` with action `generate_harness`.
+4. If `report.executed` is true and `report.status == "blocked"`, emit structured case blockers for `case_results` whose status is `blocked`, using `evidence` first and warning messages second.
+5. Only if no structured runner blocker exists, read `workspace / combined_log_path`, bound it to 8,192 characters, and emit one `runner_reported_blocked` with action `open_execution_log`.
+
+Never read a log path that escapes the workspace. When containment fails, omit the excerpt and fall through to `execution_blocked_unknown`.
+
