{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unit-test-runner.local/schemas/common.schema.json",
  "title": "unitTestRunner artifact envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "schema_version",
    "producer",
    "subject",
    "data",
    "extensions"
  ],
  "properties": {
    "artifact_kind": {"type": "string", "minLength": 1},
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "producer": {"$ref": "#/$defs/producer"},
    "subject": {"$ref": "#/$defs/subject"},
    "data": {"type": "object"},
    "extensions": {"type": "object"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "commit"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "minLength": 1}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["function_id", "source_path", "source_sha256"],
      "properties": {
        "function_id": {"type": "string", "minLength": 1},
        "source_path": {"type": "string", "minLength": 1},
        "source_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_kind", "path", "sha256"],
      "properties": {
        "artifact_kind": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
